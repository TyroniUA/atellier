# Resend — transactional email
RESEND_API_KEY=
# Inbox that receives contact form submissions
CONTACT_TO_EMAIL=
# Verified sender address. For first run you can use "Atelier <onboarding@resend.dev>"
# (sandbox; only delivers to your verified Resend account email).
CONTACT_FROM_EMAIL="Atelier <onboarding@resend.dev>"

# PostHog — analytics, heatmaps, session replay
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
